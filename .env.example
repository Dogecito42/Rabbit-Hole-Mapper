# Conexion Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Ollama
OLLAMA_HOST=http://localhost:11434

# Crawler
# Numero de videos por sesion si no se pasa --videos en CLI
CRAWLER_DEFAULT_VIDEOS=50
# Delay minimo y maximo entre acciones (segundos)
CRAWLER_DELAY_MIN=2
CRAWLER_DELAY_MAX=8
PLAYWRIGHT_BROWSERS_PATH=path
